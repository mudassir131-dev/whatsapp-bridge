# ==========================================
# WhatsApp-Telegram Bridge Configuration
# ==========================================

# ----------------------------
# Telegram Bot Configuration
# ----------------------------
# Token received from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of authorized Telegram user/admin IDs.
# Run /status or check via @userinfobot to find your Telegram User ID.
TELEGRAM_ADMIN_IDS=your_telegram_admin_id_here

# ----------------------------
# Groq AI Configuration
# ----------------------------
# API Key from console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Configurable Llama model. E.g., "llama-3.3-70b-versatile" (or "llama 3.3" which maps automatically)
GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------
# Optional / Custom Settings
# ----------------------------
# Enable AI auto-replies by default (true/false)
AI_ENABLED=true

# Optional system prompt to override the default AI assistant persona
# SYSTEM_PROMPT="You are a helpful AI assistant communicating through WhatsApp..."

# Optional phone number to use pairing code authentication instead of QR code.
# Must be in international format (digits only, e.g. 919876543210 - DO NOT prefix with + or 00)
# WA_PHONE_NUMBER=

# Path to session storage (default: ./auth)
# AUTH_DIR=./auth

# Path to SQLite database (default: ./data/bridge.db)
# DB_PATH=./data/bridge.db

# Max conversation messages to send as context to Groq (default: 20)
# MAX_HISTORY_MESSAGES=20

# Logging level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Node environment: development, production
NODE_ENV=development

# Port for HTTP Health Server (Render will inject this automatically in prod)
PORT=3000
